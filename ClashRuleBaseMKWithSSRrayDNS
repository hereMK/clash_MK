# https://github.com/ACL4SSR/ACL4SSR/blob/master/Clash/GeneralClashConfig.yml
# https://raw.githubusercontent.com/lzdnico/subconverteriniexample/master/config/forcerule.yml

# China DNS: 223.5.5.5:53; 223.6.6.6:53
# DNS: 8.8.8.8:53; 1.1.1.1:53

port: 7890
socks-port: 7891
allow-lan: true
mode: Rule
log-level: info
external-controller: 127.0.0.1:9090
dns:
   enable: true   
   ipv6: false
   listen: 0.0.0.0:53
   enhanced-mode: redir-host   
   fake-ip-range: 198.18.0.1/16  
   fake-ip-filter: 
      - '*.lan'
      - localhost.ptlogin2.qq.com
   nameserver:
      - 223.5.5.5   
      - 223.6.6.6
   fallback:
      - 8.8.8.8  
      - 1.1.1.1  

   fallback-filter:
      geoip: true 
      ipcidr:  
        - 240.0.0.0/4
